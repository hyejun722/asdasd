<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>스터디 플래너</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        @import url('https://fastly.jsdelivr.net/gh/projectnoonnu/noonfonts_2107@1.1/Pretendard-Regular.woff');
        body {
            font-family: 'Pretendard', sans-serif;
            background-color: #f2f4f6; 
            color: #333d4b; 
            transition: background-color 0.2s, color 0.2s;
        }
        .toss-card {
            border-radius: 24px;
            box-shadow: 0 4px 16px rgba(0,0,0,0.04);
            transition: background-color 0.2s, color 0.2s;
        }
        .toss-btn {
            background-color: #3182f6;
            color: white;
            transition: background 0.2s;
        }
        .toss-btn:hover {
            background-color: #1b64da;
        }
    </style>
</head>
<body class="p-4 md:p-8 max-w-4xl mx-auto pb-24">

    <div class="flex justify-between items-center mb-6 px-2">
        <div>
            <h1 id="mainTitle" class="text-2xl font-bold transition-colors">스터디 플래너</h1>
            <p id="studentId" class="text-sm transition-colors">학번: 10722</p>
        </div>
        <select id="themeSelect" class="p-2 border rounded-xl text-sm bg-white text-gray-800" onchange="changeTheme()">
            <option value="default">✨ 기본 화이트</option>
            <option value="dark">🌙 다크 모드</option>
            <option value="mint">🌿 민트 브리즈</option>
            <option value="pink">🌸 피치 핑크</option>
        </select>
    </div>

    <div id="badgeCard" class="toss-card p-6 mb-6 text-center bg-gradient-to-r from-blue-500 to-indigo-600 text-white">
        <p class="text-sm opacity-80">현재 나의 공부 등급</p>
        <h2 id="userTier" class="text-2xl font-bold my-1">🌱 공부 새싹</h2>
        <p class="text-xs opacity-90">총 공부 시간: <span id="totalHours">0</span>분</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        
        <div class="toss-card p-6 flex flex-col justify-between card-bg">
            <div>
                <h3 class="text-lg font-bold mb-4 card-title">⏱️ 알림 및 타이머</h3>
                <div class="mb-4">
                    <label class="block text-xs mb-1 card-subtext">매일 공부 알림 시간 설정</label>
                    <div class="flex gap-2">
                        <input type="time" id="alertTime" class="border rounded-xl p-2 text-sm flex-1 input-field">
                        <button onclick="saveAlertTime()" class="toss-btn px-4 py-2 rounded-xl text-sm font-medium">설정</button>
                    </div>
                </div>
                <hr class="my-4 dark-hr">
                <div class="text-center my-6">
                    <select id="subjectSelect" class="mb-2 p-2 border rounded-xl text-sm w-full input-field">
                        <option value="국어">국어</option>
                        <option value="수학">수학</option>
                        <option value="영어">영어</option>
                        <option value="과학">과학</option>
                        <option value="사회">사회</option>
                    </select>
                    <div id="timerDisplay" class="text-4xl font-extrabold tracking-wider my-2 timer-text">00:00:00</div>
                </div>
            </div>
            <div class="flex gap-2">
                <button id="startBtn" onclick="startTimer()" class="toss-btn flex-1 py-3 rounded-xl font-bold">시작</button>
                <button id="stopBtn" onclick="stopTimer()" class="bg-[#e8f3ff] text-[#1b64da] flex-1 py-3 rounded-xl font-bold" disabled>종료</button>
            </div>
        </div>

        <div class="toss-card p-6 card-bg">
            <h3 class="text-lg font-bold mb-4 card-title">📝 숙제 및 수행평가 (D-1 알림)</h3>
            <div class="space-y-2 mb-4">
                <input type="text" id="taskTitle" placeholder="수행평가 또는 숙제 제목" class="w-full border rounded-xl p-2 text-sm input-field">
                <div class="flex gap-2">
                    <input type="date" id="taskDate" class="border rounded-xl p-2 text-sm flex-1 input-field">
                    <button onclick="addTask()" class="toss-btn px-4 py-2 rounded-xl text-sm font-medium">등록</button>
                </div>
            </div>
            <ul id="taskList" class="space-y-2 max-h-48 overflow-y-auto">
            </ul>
        </div>

        <div class="toss-card p-6 md:col-span-2 card-bg">
            <h3 class="text-lg font-bold mb-4 card-title">📊 과목별 공부 통계</h3>
            <div class="w-full h-64">
                <canvas id="statsChart"></canvas>
            </div>
        </div>

    </div>

    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-firestore-compat.js"></script>

    <script>
        const firebaseConfig = {
            apiKey: "AIzaSyANA-lTFGboIfklqQewlVk49GUQ_Am33aE",
            authDomain: "garim-study-planner.firebaseapp.com",
            projectId: "garim-study-planner",
            storageBucket: "garim-study-planner.firebasestorage.app",
            messagingSenderId: "1048447885260",
            appId: "1:1048447885260:web:935234dd0c96860583c769"
        };

        firebase.initializeApp(firebaseConfig);
        const db = firebase.firestore();
        const docRef = db.collection("students").doc("10722");

        let timerInterval = null;
        let secondsElapsed = 0;
        let chartInstance = null;
        let localData = {
            alertTime: "",
            tasks: [],
            stats: { "국어": 0, "수학": 0, "영어": 0, "과학": 0, "사회": 0 },
            theme: "default"
        };

        window.addEventListener('DOMContentLoaded', () => {
            if (Notification.permission !== "granted") {
                Notification.requestPermission();
            }
            loadData();
            setInterval(checkNotifications, 60000);
        });

        async function loadData() {
            try {
                const doc = await docRef.get();
                if (doc.exists) {
                    localData = { ...localData, ...doc.data() };
                }
                updateUI();
            } catch (e) {
                console.error("데이터 로딩 실패:", e);
            }
        }

        async function saveData() {
            try {
                await docRef.set(localData);
            } catch (e) {
                console.error("데이터 저장 실패:", e);
            }
        }

        function updateUI() {
            if(localData.alertTime) document.getElementById('alertTime').value = localData.alertTime;
            
            if(localData.theme) {
                document.getElementById('themeSelect').value = localData.theme;
                applyThemeStyles(localData.theme);
            }

            let totalMin = 0;
            if (localData.stats) {
                for (let sub in localData.stats) {
                    totalMin += localData.stats[sub] || 0;
                }
            }
            document.getElementById('totalHours').innerText = totalMin;

            let tier = "🌱 공부 새싹";
            let bgClass = "from-blue-500 to-indigo-600";
            if (totalMin >= 600) { 
                tier = "👑 공부의 신"; 
                bgClass = "from-purple-600 to-pink-600"; 
            } else if (totalMin >= 300) { 
                tier = "🔥 열정 장인"; 
                bgClass = "from-orange-500 to-red-500"; 
            } else if (totalMin >= 100) { 
                tier = "🏃 꾸준한 러너"; 
                bgClass = "from-green-500 to-teal-600"; 
            }
            
            const badgeCard = document.getElementById('badgeCard');
            if (badgeCard) {
                badgeCard.className = `toss-card p-6 mb-6 text-center bg-gradient-to-r ${bgClass} text-white`;
                document.getElementById('userTier').innerText = tier;
            }

            renderTaskList();
            renderChart();
        }

        function renderTaskList() {
            const taskList = document.getElementById('taskList');
            if (!taskList) return;
            taskList.innerHTML = "";
            const theme = localData.theme;

            (localData.tasks || []).forEach((t, index) => {
                const isCompleted = !!t.completed; 
                const li = document.createElement('li');
                li.className = "flex justify-between items-center p-3 rounded-xl text-sm transition-colors";
                
                if (theme === 'dark') {
                    li.style.backgroundColor = "#2a2a2a";
                    li.style.color = isCompleted ? "#10b981" : "#e2e8f0";
                } else if (theme === 'mint') {
                    li.style.backgroundColor = "#edf9f4";
                    li.style.color = isCompleted ? "#059669" : "#233a31";
                } else if (theme === 'pink') {
                    li.style.backgroundColor = "#fff0f0";
                    li.style.color = isCompleted ? "#059669" : "#4a2828";
                } else {
                    li.style.backgroundColor = "#f8f9fa";
                    li.style.color = isCompleted ? "#059669" : "#191f28";
                }

                li.innerHTML = `
                    <div class="flex items-center gap-2">
                        <input type="checkbox" onchange="toggleTask(${index})" ${isCompleted ? 'checked' : ''} class="w-4 h-4 rounded accent-emerald-500 cursor-pointer">
                        <span class="font-medium ${isCompleted ? 'text-emerald-600 dark:text-emerald-400' : ''}">
                            ${t.title} 
                            ${isCompleted ? '<span class="text-xs font-bold text-emerald-500 ml-1">(완료)</span>' : ''}
                        </span>
                        <span class="text-xs opacity-60 ml-1">~${t.date}</span>
                    </div>
                    <button onclick="deleteTask(${index})" class="text-red-500 hover:text-red-700 text-xs font-semibold">삭제</button>
                `;
                taskList.appendChild(li);
            });
        }

        async function toggleTask(index) {
            if (!localData.tasks || !localData.tasks[index]) return;
            localData.tasks[index].completed = !localData.tasks[index].completed;
            await saveData();
            updateUI();
        }

        function startTimer() {
            document.getElementById('startBtn').disabled = true;
            document.getElementById('stopBtn').disabled = false;
            document.getElementById('subjectSelect').disabled = true;

            timerInterval = setInterval(() => {
                secondsElapsed++;
                let hrs = String(Math.floor(secondsElapsed / 3600)).padStart(2, '0');
                let mins = String(Math.floor((secondsElapsed % 3600) / 60)).padStart(2, '0');
                let secs = String(secondsElapsed % 60).padStart(2, '0');
                document.getElementById('timerDisplay').innerText = `${hrs}:${mins}:${secs}`;
            }, 1000);
        }

        async function stopTimer() {
            clearInterval(timerInterval);
            document.getElementById('startBtn').disabled = false;
            document.getElementById('stopBtn').disabled = true;
            document.getElementById('subjectSelect').disabled = false;

            const selectedSubject = document.getElementById('subjectSelect').value;
            const minutesEarned = Math.round(secondsElapsed / 60);

            if (minutesEarned > 0) {
                if (!localData.stats) localData.stats = { "국어": 0, "수학": 0, "영어": 0, "과학": 0, "사회": 0 };
                localData.stats[selectedSubject] = (localData.stats[selectedSubject] || 0) + minutesEarned;
                await saveData();
                updateUI();
            }

            secondsElapsed = 0;
            document.getElementById('timerDisplay').innerText = "00:00:00";
        }

        async function addTask() {
            const title = document.getElementById('taskTitle').value.trim();
            const date = document.getElementById('taskDate').value;
            if (!title || !date) return alert("제목과 기한을 모두 입력해주세요!");

            if (!localData.tasks) localData.tasks = [];
            localData.tasks.push({ title, date, notified: false, completed: false });
            
            document.getElementById('taskTitle').value = "";
            document.getElementById('taskDate').value = "";
            
            await saveData();
            updateUI();
        }

        async function deleteTask(index) {
            if (!localData.tasks) return;
            localData.tasks.splice(index, 1);
            await saveData();
            updateUI();
        }

        async function saveAlertTime() {
            const t = document.getElementById('alertTime').value;
            if(!t) return alert("시간을 정해주세요.");
            localData.alertTime = t;
            await saveData();
            alert("매일 공부 알림 시간이 저장되었습니다.");
        }

        async function changeTheme() {
            const theme = document.getElementById('themeSelect').value;
            localData.theme = theme;
            applyThemeStyles(theme);
            renderTaskList(); 
            renderChart();    
            await saveData();
        }

        function applyThemeStyles(theme) {
            const mainTitle = document.getElementById('mainTitle');
            const studentId = document.getElementById('studentId');
            const cards = document.querySelectorAll('.card-bg');
            const cardTitles = document.querySelectorAll('.card-title');
            const cardSubtexts = document.querySelectorAll('.card-subtext');
            const timerDisplay = document.getElementById('timerDisplay');
            const inputs = document.querySelectorAll('.input-field');
            const themeSelect = document.getElementById('themeSelect');
            const hrs = document.querySelectorAll('.dark-hr');

            if (theme === 'dark') {
                document.body.style.backgroundColor = "#121212";
                document.body.style.color = "#ffffff";
                
                if(mainTitle) mainTitle.style.color = "#ffffff";
                if(studentId) studentId.style.color = "#a0aec0";
                if(timerDisplay) timerDisplay.style.color = "#ffffff";
                if(themeSelect) themeSelect.className = "p-2 border border-gray-700 rounded-xl text-sm bg-[#1e1e1e] text-white";

                cards.forEach(c => c.style.backgroundColor = "#1e1e1e");
                cardTitles.forEach(t => t.style.color = "#ffffff");
                cardSubtexts.forEach(s => s.style.color = "#a0aec0");
                inputs.forEach(i => {
                    i.style.backgroundColor = "#2a2a2a";
                    i.style.color = "#ffffff";
                    i.style.borderColor = "#4a4a4a";
                });
                hrs.forEach(h => h.style.borderColor = "#333333");

            } else {
                if(mainTitle) mainTitle.style.color = "#191f28";
                if(timerDisplay) timerDisplay.style.color = "#191f28";
                
                cardTitles.forEach(t => t.style.color = "#191f28");
                inputs.forEach(i => {
                    i.style.backgroundColor = "#ffffff";
                    i.style.color = "#000000";
                    i.style.borderColor = "#e2e8f0";
                });
                hrs.forEach(h => h.style.borderColor = "#f1f5f9");

                if (theme === 'mint') {
                    document.body.style.backgroundColor = "#f4fcf9";
                    document.body.style.color = "#233a31";
                    if(studentId) studentId.style.color = "#4a6b5d";
                    if(themeSelect) themeSelect.className = "p-2 border border-emerald-200 rounded-xl text-sm bg-white text-gray-800";
                    cards.forEach(c => c.style.backgroundColor = "#ffffff");
                    cardSubtexts.forEach(s => s.style.color = "#4a6b5d");
                } else if (theme === 'pink') {
                    document.body.style.backgroundColor = "#fff5f5";
                    document.body.style.color = "#4a2828";
                    if(studentId) studentId.style.color = "#8c6262";
                    if(themeSelect) themeSelect.className = "p-2 border border-rose-200 rounded-xl text-sm bg-white text-gray-800";
                    cards.forEach(c => c.style.backgroundColor = "#ffffff");
                    cardSubtexts.forEach(s => s.style.color = "#8c6262");
                } else {
                    document.body.style.backgroundColor = "#f2f4f6";
                    document.body.style.color = "#333d4b";
                    if(studentId) studentId.style.color = "#8b95a1";
                    if(themeSelect) themeSelect.className = "p-2 border border-gray-200 rounded-xl text-sm bg-white text-gray-800";
                    cards.forEach(c => c.style.backgroundColor = "#ffffff");
                    cardSubtexts.forEach(s => s.style.color = "#6b7684");
                }
            }
        }

        function checkNotifications() {
            const now = new Date();
            const currentHHMM = String(now.getHours()).padStart(2, '0') + ":" + String(now.getMinutes()).padStart(2, '0');
            
            if (localData.alertTime === currentHHMM) {
                sendWebNotification("📚 공부할 시간이에요!", "오늘 계획한 공부를 시작해보세요.");
            }

            const tomorrow = new Date();
            tomorrow.setDate(now.getDate() + 1);
            const tomorrowStr = tomorrow.toISOString().split('T')[0];

            let updated = false;
            if (localData.tasks) {
                localData.tasks.forEach(t => {
                    if (t.date === tomorrowStr && !t.notified) {
                        sendWebNotification("⏰ 수행평가/숙제 D-1 알림", `내일(${t.date}) 제출해야 하는 '${t.title}'이(가) 있습니다!`);
                        t.notified = true;
                        updated = true;
                    }
                });
            }

            if(updated) saveData();
        }

        function sendWebNotification(title, body) {
            if (Notification.permission === "granted") {
                new Notification(title, { body, icon: 'https://toss.im/favicon.ico' });
            }
        }

        function renderChart() {
            const canvas = document.getElementById('statsChart');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            
            const stats = localData.stats || { "국어": 0, "수학": 0, "영어": 0, "과학": 0, "사회": 0 };
            const labels = Object.keys(stats);
            const data = Object.values(stats);
            const isDark = localData.theme === 'dark';

            if (chartInstance) {
                chartInstance.destroy();
            }

            chartInstance = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: '공부 시간 (분)',
                        data: data,
                        backgroundColor: '#3182f6',
                        borderRadius: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: {
                            grid: { color: isDark ? '#333333' : '#e2e8f0' },
                            ticks: { color: isDark ? '#ffffff' : '#333333' }
                        },
                        y: { 
                            beginAtZero: true,
                            grid: { color: isDark ? '#333333' : '#e2e8f0' },
                            ticks: { color: isDark ? '#ffffff' : '#333333' }
                        }
                    },
                    plugins: {
                        legend: {
                            labels: { color: isDark ? '#ffffff' : '#333333' }
                        }
                    }
                }
            });
        }
    </script>
</body>
</html>
